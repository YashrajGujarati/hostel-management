{
  "version": 2,
  "installCommand": "npm install --prefix frontend --include=dev && npm install --prefix backend",
  "buildCommand": "cd frontend && npx vite build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

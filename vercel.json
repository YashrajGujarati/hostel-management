{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/|_next/static/|_next/image|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}